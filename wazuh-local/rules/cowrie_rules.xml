<group name="cowrie,">
  <!-- Base rule: matches any Cowrie JSON log line -->
  <rule id="110001" level="3">
    <decoded_as>json</decoded_as>
    <field name="eventid">^cowrie\.</field>
    <description>Cowrie Honeypot Event: $(eventid)</description>
  </rule>

  <!-- New SSH connection to the honeypot -->
  <rule id="110002" level="5">
    <if_sid>110001</if_sid>
    <field name="eventid">^cowrie.session.connect$</field>
    <description>Cowrie: New SSH connection from $(src_ip)</description>
    <group>authentication_success,</group>
  </rule>

  <!-- Failed login attempt -->
  <rule id="110003" level="7">
    <if_sid>110001</if_sid>
    <field name="eventid">^cowrie.login.failed$</field>
    <description>Cowrie: Login attempt failed for user '$(username)'</description>
    <group>authentication_failed,</group>
  </rule>

  <!-- Successful honeypot login -->
  <rule id="110004" level="10">
    <if_sid>110001</if_sid>
    <field name="eventid">^cowrie.login.success$</field>
    <description>Cowrie: Attacker logged into honeypot as '$(username)'</description>
    <group>authentication_success,pci_dss_10.2.4,</group>
  </rule>

  <!-- Command executed inside the honeypot -->
  <rule id="110005" level="8">
    <if_sid>110001</if_sid>
    <field name="eventid">^cowrie.command.input$</field>
    <description>Cowrie: Attacker executed command: $(input)</description>
  </rule>

  <!-- Attacker downloaded or uploaded a file -->
  <rule id="110006" level="12">
    <if_sid>110001</if_sid>
    <field name="eventid">^cowrie.session.file_download$|^cowrie.session.file_upload$</field>
    <description>Cowrie: Attacker downloaded/uploaded a file ($(url))</description>
  </rule>
</group>
